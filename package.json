{
  "name": "temporal-training-agentic-loan-origination",
  "version": "1.0.0",
  "private": true,
  "description": "A 3-hour, hands-on workshop: build a durable loan-origination workflow with an agentic AI underwriter on Temporal.",
  "scripts": {
    "local-llm": "bash scripts/local_llm.sh",
    "local-llm:down": "bash scripts/local_llm.sh down",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node scripts/course-sandbox-runner.mjs",
    "course:data": "node scripts/build-course-site.mjs",
    "course:build": "vite build --config course/vite.config.mjs",
    "course:serve": "vite --config course/vite.config.mjs --host 127.0.0.1 --port 4173",
    "course:preview": "trap \"kill 0\" EXIT; vite build --config course/vite.config.mjs --watch & vite preview --config course/vite.config.mjs --host 127.0.0.1 --port 4173",
    "course:sandbox": "node --watch scripts/course-sandbox-runner.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@daytonaio/sdk": "^0.183.0",
    "@temporalio/activity": "^1.16.1",
    "@temporalio/client": "^1.16.1",
    "@temporalio/worker": "^1.16.1",
    "@temporalio/workflow": "^1.16.1",
    "ai": "^4.3.19",
    "codemirror": "^6.0.2",
    "vue": "^3.5.35",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tsconfig/node18": "^18.2.4",
    "@types/node": "^22.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^8.0.14"
  }
}
